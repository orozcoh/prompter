# OpenRouter API key for AI image generation
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here

# AI model to use for image generation
GENERATION_MODEL=sourceful/riverflow-v2-fast-preview

# x402 payment configuration
X402_PRICE_USD=0.10
X402_PAY_TO_ADDRESS=0x7B3193eEb2d754d126b70A1F184659D52740D306

# Payment validation
# Set to 'true' to bypass payment (free local dev)
# Set to 'false' to enable real payments (requires FACILITATOR_PRIVATE_KEY)
LOCAL_DEV_BYPASS_PAYMENT=true

# Facilitator private key (for production payments)
# This wallet pays gas fees to settle user payments on-chain
# The USDC payments go to X402_PAY_TO_ADDRESS, not this wallet
# WARNING: Never commit this file with a real private key!
# FACILITATOR_PRIVATE_KEY=0x<your-facilitator-wallet-private-key>

# Note: Facilitator is embedded in the worker - no separate URL needed
# To use an external facilitator, set X402_FACILITATOR_URL
