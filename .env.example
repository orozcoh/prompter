# OpenRouter API key for AI image generation
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here

# AI model to use for image generation (fallback if tier-specific models not set)
GENERATION_LOW_MODEL=sourceful/riverflow-v2-fast
GENERATION_HIGH_MODEL=google/gemini-3.1-flash-image-preview

# Tier-specific AI models
GENERATION_LOW_MODEL=sourceful/riverflow-v2-fast
GENERATION_HIGH_MODEL=google/gemini-3.1-flash-image-preview

# Tier-specific AI models
GENERATION_LOW_MODEL=sourceful/riverflow-v2-fast
GENERATION_HIGH_MODEL=google/gemini-3.1-flash-image-preview

# Tier-specific prices (USD)
X402_LOW_PRICE_USD=0.01
X402_HIGH_PRICE_USD=0.05
X402_PAY_TO_ADDRESS=0x7B3193eEb2d754d126b70A1F184659D52740D306

# Payment validation
# Set to 'true' to bypass payment (free local dev)
# Set to 'false' to enable real payments (on-chain verification)
LOCAL_DEV_BYPASS_PAYMENT=true

# Base RPC URL (optional - defaults to mainnet)
# For testnet: https://sepolia.base.org
BASE_RPC_URL=https://mainnet.base.org

# Minimum confirmations required (optional - defaults to 3)
MIN_CONFIRMATIONS=3
